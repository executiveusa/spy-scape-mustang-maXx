# Agent MAXX private BFF / Hermes runtime
# Set these in Coolify/VPS, not in the public browser.

MAXX_ENV=production
MAXX_ALLOWED_ORIGINS=https://spy-scape-mustang-maxx.vercel.app,https://your-vercel-preview.vercel.app
MAXX_BFF_SHARED_SECRET=replace-with-a-generated-32-byte-secret
MAXX_DATA_DIR=/data/maxx
MAXX_HERMES_HOME=/runtime/hermes
MAXX_HERMES_VENDOR_PATH=/opt/hermes-agent
MAXX_HERMES_PROVIDER=openrouter
MAXX_HERMES_MODEL=openrouter/owl-alpha
MAXX_OPENROUTER_API_KEY=sk-or-v1-...

# Keep the BFF private while app-level auth is deferred.
MAXX_ALLOW_PUBLIC_BFF=false
