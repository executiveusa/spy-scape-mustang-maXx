# Agent MAXX 006 - Environment Variables
# Copy this to .env.local for local development

# Local BFF
MAXX_ENV=development
MAXX_BFF_URL=http://127.0.0.1:8010
NEXT_PUBLIC_MAXX_BFF_URL=http://127.0.0.1:8010
MAXX_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:3011,http://localhost:3011
MAXX_ALLOW_LOCAL_BFF_IN_PRODUCTION=false
MAXX_ALLOW_PUBLIC_BFF=false
MAXX_DATA_DIR=backend/data
MAXX_HERMES_HOME=backend/runtime/hermes
MAXX_HERMES_VENDOR_PATH=E:\ACTIVE PROJECTS-PIPELINE\ACTIVE PROJECTS-PIPELINE\AFROMATIONS\vendors\hermes-agent
MAXX_OPENROUTER_API_KEY=your-openrouter-api-key-here
MAXX_HERMES_PROVIDER=openrouter
MAXX_HERMES_MODEL=openrouter/owl-alpha

# AI Services
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
GOOGLE_API_KEY=your-google-api-key-here

# Nanon Banana (if using)
NANON_BANANA_API_KEY=your-nanon-banana-key

# Coolify Deployment
COOLIFY_URL=https://your-coolify-instance.com
COOLIFY_API_TOKEN=your-coolify-api-token-here

# Image Assets
NEXT_PUBLIC_BASE_URL=http://localhost:3000

