# Mustang Maxx 006 - Environment Variables
# Copy this to .env.local for local development

# Authentication (Demo mode - team only)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=mustang-maxx-secret-key-change-in-production

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email Auth (demo credentials)
EMAIL_SERVER_HOST=smtp.gmail.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=demo@mustangmaxx.com
EMAIL_SERVER_PASSWORD=demo123456
EMAIL_FROM=demo@mustangmaxx.com

# Demo User Credentials (hardcoded for team access)
DEMO_EMAIL=demo@mustangmaxx.com
DEMO_PASSWORD=demo123456

# AI Services
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
GOOGLE_API_KEY=your-google-api-key-here

# Nanon Banana (if using)
NANON_BANANA_API_KEY=your-nanon-banana-key

# Coolify Deployment
COOLIFY_URL=https://your-coolify-instance.com
COOLIFY_API_TOKEN=your-coolify-api-token-here

# Image Assets
NEXT_PUBLIC_BASE_URL=http://localhost:3000

