{
  "$schema": "https://cdn.coollabs.io/coolify/schema.json",
  "name": "mustang-maxx-006",
  "version": "1.0.0",
  "description": "SpyScape-inspired Mustang Maxx 006 — Coolify Dockerfile Deployment",
  "type": "dockerfile",
  "dockerfile": "Dockerfile",
  "build": {
    "baseDirectory": "/"
  },
  "settings": {
    "isAutoDeployEnabled": true,
    "branch": "main"
  },
  "environment": [
    {
      "key": "NODE_ENV",
      "value": "production"
    },
    {
      "key": "NEXT_TELEMETRY_DISABLED",
      "value": "1"
    },
    {
      "key": "HOSTNAME",
      "value": "0.0.0.0"
    }
  ],
  "ports": {
    "exposePort": 3000
  },
  "healthCheck": {
    "enabled": true,
    "path": "/",
    "interval": 30,
    "timeout": 10,
    "retries": 3,
    "startPeriod": 20
  }
}
