# ============================================
# Mustang Maxx 006 - Environment Variables
# ============================================
# Copy this to .env.local for development
# Set these as Environment Variables in Coolify for production

# NextAuth - REQUIRED for production
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (optional - demo login works without these)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Demo credentials (defaults shown, override if desired)
# DEMO_EMAIL=demo@mustangmaxx.com
# DEMO_PASSWORD=demo123456
